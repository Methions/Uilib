	function Options:AddKeybind(Settings: { Title: string, Description: string, Tab: Instance, Callback: any }) 
		local Dropdown = Clone(Components["Keybind"]);
		local Title, Description = Options:GetLabels(Dropdown);
		local Bind = Dropdown["Main"].Options;
		local BindParent = Bind.Parent;
		
		local Mouse = { Enum.UserInputType.MouseButton1, Enum.UserInputType.MouseButton2, Enum.UserInputType.MouseButton3 }; 
		local Types = { 
			["Mouse"] = "Enum.UserInputType.MouseButton", 
			["Key"] = "Enum.KeyCode." 
		}
		
		local WaitingConnection = nil
		local DotTweens = {}
		local DotContainer = nil
		local CurrentDetect = nil
		
		local function StopWaitingAnimation()
			if CurrentDetect then
				pcall(function() CurrentDetect:Disconnect() end)
				CurrentDetect = nil
			end
			if WaitingConnection then
				pcall(function() WaitingConnection:Disconnect() end)
				WaitingConnection = nil
			end
			for _, T in ipairs(DotTweens) do
				if T then pcall(function() T:Cancel() end) end
			end
			table.clear(DotTweens)
			
			-- Remove dot container
			if DotContainer and DotContainer.Parent then
				Destroy(DotContainer)
				DotContainer = nil
			end
		end
		
		local function PlayWaitingAnimation()
			StopWaitingAnimation()
			
			-- Hide original text
			Bind.Visible = false
			
			-- Create dot container inside same parent as Bind, same position/size
			DotContainer = Instance.new("Frame")
			DotContainer.Name = "DotContainer"
			DotContainer.BackgroundTransparency = 1
			DotContainer.Size = Bind.Size
			DotContainer.Position = Bind.Position
			DotContainer.AnchorPoint = Bind.AnchorPoint
			DotContainer.Parent = BindParent
			
			-- Create 3 individual dot labels centered in container
			local DotLabels = {}
			local TotalWidth = 24 -- 3 dots * 8px spacing
			local StartX = -TotalWidth / 2
			
			for i = 1, 3 do
				local Dot = Instance.new("TextLabel")
				Dot.Name = "Dot"..i
				Dot.Text = "."
				Dot.Font = Bind.Font
				Dot.TextSize = Bind.TextSize
				Dot.TextColor3 = Bind.TextColor3
				Dot.BackgroundTransparency = 1
				Dot.Size = UDim2.new(0, 8, 1, 0)
				Dot.Position = UDim2.new(0.5, StartX + (i - 1) * 8, 0.5, 0)
				Dot.AnchorPoint = Vector2.new(0.5, 0.5)
				Dot.TextXAlignment = Enum.TextXAlignment.Center
				Dot.TextYAlignment = Enum.TextYAlignment.Center
				Dot.Parent = DotContainer
				table.insert(DotLabels, Dot)
			end
			
			local Running = true
			
			local function AnimateDot(Dot, Delay)
				task.spawn(function()
					task.wait(Delay)
					while Running and Dot and Dot.Parent do
						-- Up
						local T1 = Services.Tween:Create(Dot, TweenInfo.new(0.25, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
							Position = UDim2.new(Dot.Position.X.Scale, Dot.Position.X.Offset, 0.5, -4)
						})
						table.insert(DotTweens, T1)
						T1:Play()
						T1.Completed:Wait()
						
						if not Running or not Dot or not Dot.Parent then break end
						
						-- Down
						local T2 = Services.Tween:Create(Dot, TweenInfo.new(0.25, Enum.EasingStyle.Sine, Enum.EasingDirection.In), {
							Position = UDim2.new(Dot.Position.X.Scale, Dot.Position.X.Offset, 0.5, 0)
						})
						table.insert(DotTweens, T2)
						T2:Play()
						T2.Completed:Wait()
						
						if not Running or not Dot or not Dot.Parent then break end
						
						-- Wait before next wave cycle
						task.wait(0.15)
					end
				end)
			end
			
			-- Stagger each dot by 0.12 seconds
			for i, Dot in ipairs(DotLabels) do
				AnimateDot(Dot, (i - 1) * 0.12)
			end
		end
		
		Connect(Dropdown.MouseButton1Click, function()
			StopWaitingAnimation()
			PlayWaitingAnimation()
			
			local Finished = false
			
			CurrentDetect = Connect(game.UserInputService.InputBegan, function(Key, Focused) 
				if Finished then return end
				if Focused then return end
				
				local InputType = Key.UserInputType
				
				Finished = true
				StopWaitingAnimation()
				Bind.Visible = true
				
				if table.find(Mouse, InputType) then
					Settings.Callback(Key);
					SetProperty(Bind, {
						Text = tostring(InputType):gsub(Types.Mouse, "MB")
					})
				elseif InputType == Enum.UserInputType.Keyboard then
					Settings.Callback(Key);
					SetProperty(Bind, {
						Text = tostring(Key.KeyCode):gsub(Types.Key, "")
					})
				end
			end)
		end)

		Animations:Component(Dropdown);
		SetProperty(Title, { Text = Settings.Title });
		SetProperty(Description, { Text = Settings.Description });
		SetProperty(Dropdown, {
			Name = Settings.Title,
			Parent = Settings.Tab,
			Visible = true,
		})
	end

function Options:AddDropdown(Settings: {
	Title: string,
	Description: string,
	Options: {},
	Tab: Instance,
	Callback: any,
	Search: boolean?,
	Multi: boolean?
})
	local Dropdown = Clone(Components["Dropdown"])
	local Title, Description = Options:GetLabels(Dropdown)
	local Text = Dropdown["Main"].Options

	local IsOpen = false
	local CurrentDropdown = nil
	local SelectedValues = {}
	local OutsideConnection = nil
	local TopButtonConnections = {}

	local function IsPointInsideGui(GuiObject, Point)
		if not GuiObject or not GuiObject:IsA("GuiObject") then
			return false
		end

		local Pos = GuiObject.AbsolutePosition
		local Size = GuiObject.AbsoluteSize

		return Point.X >= Pos.X and Point.X <= Pos.X + Size.X and Point.Y >= Pos.Y and Point.Y <= Pos.Y + Size.Y
	end

	local function DisconnectTopButtons()
		for _, Connection in ipairs(TopButtonConnections) do
			if Connection and Connection.Disconnect then
				Connection:Disconnect()
			end
		end
		table.clear(TopButtonConnections)
	end

	local function CloseDropdown()
		if not IsOpen then
			return
		end

		IsOpen = false

		if OutsideConnection then
			OutsideConnection:Disconnect()
			OutsideConnection = nil
		end

		DisconnectTopButtons()

		Tween(BG, .25, { BackgroundTransparency = 1 })

		if CurrentDropdown then
			local ToDestroy = CurrentDropdown
			CurrentDropdown = nil
			Animations:Close(ToDestroy)

			task.delay(0.2, function()
				if ToDestroy then
					Destroy(ToDestroy)
				end
			end)
		end
	end

	local function UpdateDisplay()
		if Settings.Multi then
			local Names = {}

			for Name, Enabled in pairs(SelectedValues) do
				if Enabled then
					table.insert(Names, Name)
				end
			end

			Text.Text = #Names > 0 and table.concat(Names, ", ") or "Select"
		end
	end

	Connect(Dropdown.MouseButton1Click, function()
		if IsOpen then
			CloseDropdown()
			return
		end

		IsOpen = true

		local Example = Clone(Examples["DropdownExample"])
		CurrentDropdown = Example

		Tween(BG, .25, { BackgroundTransparency = 0.6 })
		SetProperty(Example, { Parent = Window })
		Animations:Open(Example, 0, true)

		local ScrollFrame = Example.ScrollingFrame

		local UIList = Instance.new("UIListLayout")
		UIList.Padding = UDim.new(0, 6)
		UIList.Parent = ScrollFrame

		local SearchBox = nil

		if Settings.Search then
			local Holder = Instance.new("Frame")
			Holder.Size = UDim2.new(1, 0, 0, 36)
			Holder.BackgroundTransparency = 1
			Holder.Parent = ScrollFrame

			SearchBox = Instance.new("TextBox")
			SearchBox.Size = UDim2.new(1, -20, 1, 0)
			SearchBox.Position = UDim2.new(0, 10, 0, 0)
			SearchBox.BackgroundColor3 = Theme.Component
			SearchBox.Text = ""
			SearchBox.PlaceholderText = "Search"
			SearchBox.TextSize = 14
			SearchBox.ClearTextOnFocus = false
			SearchBox.Font = Enum.Font.Gotham
			SearchBox.TextXAlignment = Enum.TextXAlignment.Left
			SearchBox.TextColor3 = Theme.Text or Color3.fromRGB(255, 255, 255)
			SearchBox.PlaceholderColor3 = Theme.SubText or Color3.fromRGB(170, 170, 170)
			SearchBox.Parent = Holder

			local Corner = Instance.new("UICorner")
			Corner.CornerRadius = UDim.new(0, 8)
			Corner.Parent = SearchBox

			local Padding = Instance.new("UIPadding")
			Padding.PaddingLeft = UDim.new(0, 10)
			Padding.PaddingRight = UDim.new(0, 10)
			Padding.Parent = SearchBox
		end

		local function RefreshOptions(FilterText)
			for _, Child in ipairs(ScrollFrame:GetChildren()) do
				if Child:IsA("TextButton") then
					Destroy(Child)
				end
			end

			for Index, Option in pairs(Settings.Options) do
				local Name = tostring(Index)

				if not FilterText or Name:lower():find(FilterText:lower(), 1, true) then
					local Button = Clone(Examples["DropdownButtonExample"])
					local BtnTitle, BtnDescription = Options:GetLabels(Button)

					if BtnDescription then
						Destroy(BtnDescription)
					end

					SetProperty(BtnTitle, { Text = Name })
					SetProperty(Button, {
						Parent = ScrollFrame,
						Visible = true
					})

					if Settings.Multi then
						if SelectedValues[Name] then
							Button.BackgroundColor3 = Theme.Interactables
						else
							Button.BackgroundColor3 = Theme.Component
						end
					end

					Connect(Button.MouseButton1Click, function()
						if Settings.Multi then
							SelectedValues[Name] = not SelectedValues[Name]

							if SelectedValues[Name] then
								Tween(Button, .25, {
									BackgroundColor3 = Theme.Interactables
								})
							else
								Tween(Button, .25, {
									BackgroundColor3 = Theme.Component
								})
							end

							UpdateDisplay()
							Settings.Callback(SelectedValues)
						else
							Text.Text = Name
							Settings.Callback(Option)
							CloseDropdown()
						end
					end)
				end
			end
		end

		local Buttons = Example:FindFirstChild("Top") and Example.Top:FindFirstChild("Buttons")
		if Buttons then
			for _, Button in ipairs(Buttons:GetChildren()) do
				if Button:IsA("TextButton") then
					Animations:Component(Button, true)
					table.insert(TopButtonConnections, Connect(Button.MouseButton1Click, function()
						CloseDropdown()
					end))
				end
			end
		end

		RefreshOptions()

		if SearchBox then
			Connect(SearchBox:GetPropertyChangedSignal("Text"), function()
				RefreshOptions(SearchBox.Text)
			end)
		end

		OutsideConnection = Connect(UserInputService.InputBegan, function(Input)
			if not IsOpen then
				return
			end

			if Input.UserInputType == Enum.UserInputType.MouseButton1 then
				local MousePos = UserInputService:GetMouseLocation()
				local InsideDropdown = false

				if CurrentDropdown and IsPointInsideGui(CurrentDropdown, MousePos) then
					InsideDropdown = true
				end

				if IsPointInsideGui(Dropdown, MousePos) then
					InsideDropdown = true
				end

				if not InsideDropdown then
					CloseDropdown()
				end
			end
		end)
	end)

	Animations:Component(Dropdown)

	SetProperty(Title, { Text = Settings.Title })
	SetProperty(Description, { Text = Settings.Description })

	SetProperty(Dropdown, {
		Name = Settings.Title,
		Parent = Settings.Tab,
		Visible = true
	})
end

	function Options:AddSlider(Settings: { Title: string, Description: string, MaxValue: number, AllowDecimals: boolean, DecimalAmount: number, Tab: Instance, Callback: any }) 
		local Slider = Clone(Components["Slider"]);
		local Title, Description = Options:GetLabels(Slider);

		local Main = Slider["Slider"];
		local Amount = Main["Main"].Input;
		local Slide = Main["Slide"];
		local Fire = Slide["Fire"];
		local Fill = Slide["Highlight"];
		local Circle = Fill["Circle"];

		local Active = false
		local Value = 0
		
		local SetNumber = function(Number)
			if Settings.AllowDecimals then
				local Power = 10 ^ (Settings.DecimalAmount or 2)
				Number = math.floor(Number * Power + 0.5) / Power
			else
				Number = math.round(Number)
			end
			
			return Number
		end

		local Update = function(Number)
			local Scale = (Player.Mouse.X - Slide.AbsolutePosition.X) / Slide.AbsoluteSize.X			
			Scale = (Scale > 1 and 1) or (Scale < 0 and 0) or Scale
			
			if Number then
				Number = (Number > Settings.MaxValue and Settings.MaxValue) or (Number < 0 and 0) or Number
			end
			
			Value = SetNumber(Number or (Scale * Settings.MaxValue))
			Amount.Text = Value
			Fill.Size = UDim2.fromScale((Number and Number / Settings.MaxValue) or Scale, 1)
			Settings.Callback(Value)
		end

		local Activate = function()
			Active = true

			repeat task.wait()
				Update()
			until not Active
		end
		
		Connect(Amount.FocusLost, function() 
			Update(tonumber(Amount.Text) or 0)
		end)

		Connect(Fire.MouseButton1Down, Activate)
		Connect(Services.Input.InputEnded, function(Input) 
			if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
				Active = false
			end
		end)

		Fill.Size = UDim2.fromScale(Value, 1);
		Animations:Component(Slider);
		SetProperty(Title, { Text = Settings.Title });
		SetProperty(Description, { Text = Settings.Description });
		SetProperty(Slider, {
			Name = Settings.Title,
			Parent = Settings.Tab,
			Visible = true,
		})
	end

	function Options:AddParagraph(Settings: { Title: string, Description: string, Tab: Instance }) 
		local Paragraph = Clone(Components["Paragraph"]);
		local Title, Description = Options:GetLabels(Paragraph);

		SetProperty(Title, { Text = Settings.Title });
		SetProperty(Description, { Text = Settings.Description });
		SetProperty(Paragraph, {
			Parent = Settings.Tab,
			Visible = true,
		})
	end

	local Themes = {
		Names = {	
			["Paragraph"] = function(Label)
				if Label:IsA("TextButton") then
					Label.BackgroundColor3 = Color(Theme.Component, 5, "Dark");
				end
			end,
			
			["Title"] = function(Label)
				if Label:IsA("TextLabel") then
					Label.TextColor3 = Theme.Title
				end
			end,

			["Description"] = function(Label)
				if Label:IsA("TextLabel") then
					Label.TextColor3 = Theme.Description
				end
			end,
			
			["Section"] = function(Label)
				if Label:IsA("TextLabel") then
					Label.TextColor3 = Theme.Title
				end
			end,

			["Options"] = function(Label)
				if Label:IsA("TextLabel") and Label.Parent.Name == "Main" then
					Label.TextColor3 = Theme.Title
				end
			end,
			
			["Notification"] = function(Label)
				if Label:IsA("CanvasGroup") then
					Label.BackgroundColor3 = Theme.Primary
					Label.UIStroke.Color = Theme.Outline
				end
			end,

			["TextLabel"] = function(Label)
				if Label:IsA("TextLabel") and Label.Parent:FindFirstChild("List") then
					Label.TextColor3 = Theme.Tab
				end
			end,

			["Main"] = function(Label)
				if Label:IsA("Frame") then

					if Label.Parent == Window then
						Label.BackgroundColor3 = Theme.Secondary
					elseif Label.Parent:FindFirstChild("Value") then
						local Toggle = Label.Parent.Value 
						local Circle = Label:FindFirstChild("Circle")
						
						if not Toggle.Value then
							Label.BackgroundColor3 = Theme.Interactables
							Label.Circle.BackgroundColor3 = Theme.Primary
						end
					else
						Label.BackgroundColor3 = Theme.Interactables
					end
				elseif Label:FindFirstChild("Padding") then
					Label.TextColor3 = Theme.Title
				end
			end,

			["Amount"] = function(Label)
				if Label:IsA("Frame") then
					Label.BackgroundColor3 = Theme.Interactables
				end
			end,

			["Slide"] = function(Label)
				if Label:IsA("Frame") then
					Label.BackgroundColor3 = Theme.Interactables
				end
			end,

			["Input"] = function(Label)
				if Label:IsA("TextLabel") then
					Label.TextColor3 = Theme.Title
				elseif Label:FindFirstChild("Labels") then
					Label.BackgroundColor3 = Theme.Component
				elseif Label:IsA("TextBox") and Label.Parent.Name == "Main" then
					Label.TextColor3 = Theme.Title
				end
			end,

			["Outline"] = function(Stroke)
				if Stroke:IsA("UIStroke") then
					Stroke.Color = Theme.Outline
				end
			end,

			["DropdownExample"] = function(Label)
				Label.BackgroundColor3 = Theme.Secondary
			end,

			["Underline"] = function(Label)
				if Label:IsA("Frame") then
					Label.BackgroundColor3 = Theme.Outline
				end
			end,
		},

		Classes = {
			["ImageLabel"] = function(Label)
				if Label.Image ~= "rbxassetid://6644618143" then
					Label.ImageColor3 = Theme.Icon
				end
			end,

			["TextLabel"] = function(Label)
				if Label:FindFirstChild("Padding") then
					Label.TextColor3 = Theme.Title
				end
			end,

			["TextButton"] = function(Label)
				if Label:FindFirstChild("Labels") then
					Label.BackgroundColor3 = Theme.Component
				end
			end,

			["ScrollingFrame"] = function(Label)
				Label.ScrollBarImageColor3 = Theme.Component
			end,
		},
	}

	function Options:SetTheme(Info)
		Theme = Info or Theme

		if not BackgroundImage then
			Window.BackgroundTransparency = 0
			Window.BackgroundColor3 = Theme.Primary
			Sidebar.BackgroundTransparency = 0
			Sidebar.BackgroundColor3 = Theme.Primary
			Holder.BackgroundTransparency = 0
			Holder.BackgroundColor3 = Theme.Secondary
		end
		Holder.BackgroundColor3 = Theme.Secondary
		Sidebar.BackgroundColor3 = Theme.Primary
		Window.UIStroke.Color = Theme.Shadow

		for Index, Descendant in next, Screen:GetDescendants() do
			local Name, Class =  Themes.Names[Descendant.Name],  Themes.Classes[Descendant.ClassName]

			if Name then
				Name(Descendant);
			elseif Class then
				Class(Descendant);
			end
		end
	end

	--// Changing Settings

	function Options:SetSetting(Setting, Value) --// Available settings - Size, Transparency, Blur, Theme
		if Setting == "Size" then
			
			Window.Size = Value
			Setup.Size = Value
			
		elseif Setting == "Transparency" then
			
			Window.GroupTransparency = Value
			Setup.Transparency = Value
			
			for Index, Notification in next, Screen:GetDescendants() do
				if Notification:IsA("CanvasGroup") and Notification.Name == "Notification" then
					Notification.GroupTransparency = Value
				end
			end
			
		elseif Setting == "Blur" then
			
			local AlreadyBlurred, Root = Blurs[Settings.Title], nil
			
			if AlreadyBlurred then
				Root = Blurs[Settings.Title]["root"]
			end
			
			if Value then
				BlurEnabled = true

				if not AlreadyBlurred or not Root then
					Blurs[Settings.Title] = Blur.new(Window, 5)
				elseif Root and not Root.Parent then
					Root.Parent = workspace.CurrentCamera
				end
			elseif not Value and (AlreadyBlurred and Root and Root.Parent) then
				Root.Parent = nil
				BlurEnabled = false
			end
			
		elseif Setting == "Theme" and typeof(Value) == "table" then
			
			Options:SetTheme(Value)
			
		elseif Setting == "Keybind" then
			
			Setup.Keybind = Value
			
		else
			warn("Tried to change a setting that doesn't exist or isn't available to change.")
		end
	end

    
	function Options:SetBackgroundImage(Value)
		Settings.Background = Value
		SetupBackground(Value)
	end

	function Options:SetBackgroundTransparency(Value)
		local Img = BackgroundImage and BackgroundImage:FindFirstChild("Image")
		if Img then
			Img.ImageTransparency = Value
		end
	end

	function Options:SetBackgroundPanelTransparency(Value)
		Settings.BackgroundPanelTransparency = Value
		if BackgroundImage then
			SetupBackground(Settings.Background)
		end
	end

	if Settings.Background then
		SetupBackground(Settings.Background)
	end

	SetProperty(Window, { Size = Settings.Size, Visible = true, Parent = Screen });
	Animations:Open(Window, Settings.Transparency or 0)

	return Options
end

return Library
