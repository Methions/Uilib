function Library:CreateWindow(Settings: { Title: string, Size: UDim2, Transparency: number, MinimizeKeybind: Enum.KeyCode?, Blurring: boolean, Theme: string })
	local Window = Clone(Screen:WaitForChild("Main"));
	local Sidebar = Window:FindFirstChild("Sidebar");
	local Holder = Window:FindFirstChild("Main");
	local BG = Window:FindFirstChild("BackgroundShadow");
	local Tab = Sidebar:FindFirstChild("Tab");

	--// Background Image System (Content Area Only - Rounded Corners)
	local BackgroundImage = nil
	local BackgroundGradient = nil
	local OriginalTransparencies = {}

	local function SaveOriginalTransparency(Object)
		if Object and not OriginalTransparencies[Object] then
			OriginalTransparencies[Object] = Object.BackgroundTransparency
		end
	end

	local function RestoreOriginalTransparencies()
		for Object, Trans in pairs(OriginalTransparencies) do
			if Object and Object.Parent then
				Object.BackgroundTransparency = Trans
			end
		end
		OriginalTransparencies = {}
	end

	local function SetupBackground(BackgroundSetting)
		-- Cleanup old
		if BackgroundImage then
			Destroy(BackgroundImage)
			BackgroundImage = nil
		end
		if BackgroundGradient then
			Destroy(BackgroundGradient)
			BackgroundGradient = nil
		end
		RestoreOriginalTransparencies()

		-- Remove old corners we added
		for _, Child in pairs(Holder:GetChildren()) do
			if Child.Name == "BgImageCorner" then
				Destroy(Child)
			end
		end

		if not BackgroundSetting then
			Window.BackgroundTransparency = 0
			Window.BackgroundColor3 = Theme.Primary
			Sidebar.BackgroundTransparency = 0
			Sidebar.BackgroundColor3 = Theme.Primary
			Holder.BackgroundTransparency = 0
			Holder.BackgroundColor3 = Theme.Secondary
			return
		end

		-- Window solid theme color (sidebar area)
		Window.BackgroundTransparency = 0
		Window.BackgroundColor3 = Theme.Primary

		-- Sidebar stays SOLID - no image behind tabs
		Sidebar.BackgroundTransparency = 0
		Sidebar.BackgroundColor3 = Theme.Primary

		-- Holder see-through so image bleeds through content only
		SaveOriginalTransparency(Holder)
		Holder.BackgroundTransparency = Settings.BackgroundPanelTransparency or 0.15
		Holder.BackgroundColor3 = Theme.Secondary

		if typeof(BackgroundSetting) == "table" then
			-- Gradient background
			BackgroundImage = Instance.new("Frame")
			SetProperty(BackgroundImage, {
				Name = "BackgroundImage",
				Parent = Holder,
				BackgroundColor3 = Color3.new(1, 1, 1),
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 1, 0),
				ZIndex = 0,
			})

			-- Round the gradient corners (clips rendering to rounded shape)
			local BgCorner = Instance.new("UICorner")
			BgCorner.Name = "BgImageCorner"
			SetProperty(BgCorner, {
				CornerRadius = UDim.new(0, 12),
				Parent = BackgroundImage,
			})

			BackgroundGradient = Instance.new("UIGradient")
			for prop, val in next, BackgroundSetting do
				if BackgroundGradient[prop] ~= nil then
					BackgroundGradient[prop] = val
				end
			end
			BackgroundGradient.Parent = BackgroundImage

		elseif typeof(BackgroundSetting) == "string" then
			-- Image background - UICorner goes DIRECTLY on ImageLabel
			BackgroundImage = Instance.new("ImageLabel")
			SetProperty(BackgroundImage, {
				Name = "BackgroundImage",
				Parent = Holder,
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 1, 0),
				ImageTransparency = Settings.BackgroundImageTransparency or 0,
				ScaleType = Enum.ScaleType.Crop,
				ZIndex = 0,
			})

			-- THIS is what rounds the image and clips the texture
			local BgCorner = Instance.new("UICorner")
			BgCorner.Name = "BgImageCorner"
			SetProperty(BgCorner, {
				CornerRadius = UDim.new(0, 12),
				Parent = BackgroundImage,
			})

			if string.find(BackgroundSetting, "^https?://") then
				local success, result = pcall(function()
					local folder = "LateLib"
					if not isfolder(folder) then makefolder(folder) end
					
					local fileName = folder .. "/BG_" .. tostring(game:GetService("HttpService"):GenerateGUID(false)) .. ".png"
					local response = game:HttpGet(BackgroundSetting)
					writefile(fileName, response)
					
					BackgroundImage.Image = getcustomasset(fileName)
				end)
				if not success then
					warn("[Late UI] Failed to load background URL: " .. tostring(result))
					BackgroundImage.Image = ""
				end
			else
				BackgroundImage.Image = BackgroundSetting
			end
		end

		-- Push Holder content above the background image
		for _, Child in pairs(Holder:GetChildren()) do
			if Child:IsA("GuiObject") and Child ~= BackgroundImage then
				if Child.ZIndex <= 0 then
					Child.ZIndex = 1
				end
			end
		end
	end

